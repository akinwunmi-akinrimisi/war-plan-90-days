{
  "name": "WF-UI — 90-Day War Plan: Tracker UI",
  "nodes": [
    {
      "parameters": { "path": "tracker", "responseMode": "responseNode", "options": {} },
      "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 2.1,
      "position": [250, 300], "webhookId": "wf-ui-tracker"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://raw.githubusercontent.com/akinwunmi-akinrimisi/war-plan-90-days/main/90day-tracker.html",
        "options": { "response": { "response": { "responseFormat": "file" } } }
      },
      "name": "Fetch Tracker HTML", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "respondWith": "binary",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Content-Type", "value": "text/html; charset=utf-8" },
              { "name": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
          }
        }
      },
      "name": "Respond with HTML", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1,
      "position": [690, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Fetch Tracker HTML", "type": "main", "index": 0 }]] },
    "Fetch Tracker HTML": { "main": [[{ "node": "Respond with HTML", "type": "main", "index": 0 }]] }
  },
  "settings": { "timezone": "Africa/Lagos", "executionOrder": "v1" },
  "tags": [{ "name": "war-plan" }]
}

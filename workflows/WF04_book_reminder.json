    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/daily_log?day_num=eq.{{ $('Day Counter').first().json.day_number }}&select=*",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_API_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_API_KEY }}" }
          ]
        },
        "options": {}
      },
      "name": "Get Daily Log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1570, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-sonnet-4-5\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are the reading coach for Akinwunmi's 90-Day War Plan.\\nGenerate a book reminder for Day {{ $('Day Counter').first().json.day_number }}.\\n\\nTarget: 50 pages today | Pages logged so far: {{ $('Get Daily Log').first().json[0] ? $('Get Daily Log').first().json[0].book_pages || 0 : 0 }}\\nBook: {{ $('Get Daily Log').first().json[0] ? $('Get Daily Log').first().json[0].book_title || 'Check your reading list' : 'Check your reading list' }}\\nMessage type: {{ $('Book Reminder').first().json.message_type }}\\nTotal pages read (90-day): {{ $('Get Daily Log').first().json[0] ? $('Get Daily Log').first().json[0].pages_total || 0 : 0 }} / 4,500 target\\n\\nRules:\\n- pre_task: Name the book if known, set 50-page target, motivate\\n- post_task: Check progress. If 0 pages: 'You haven't read today.'\\n- Include one quote from a business/self-help author\\n- Tie reading to building the AI agency (Operscale)\\n- 60-120 words. Tone: coach, growth-focused.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate the {{ $('Book Reminder').first().json.message_type }} book reminder for Day {{ $('Day Counter').first().json.day_number }}. Target: 50 pages. Pages logged: {{ $('Get Daily Log').first().json[0] ? $('Get Daily Log').first().json[0].book_pages || 0 : 0 }}.\"\n    }\n  ],\n  \"max_tokens\": 500\n}",
        "options": {}
      },
      "name": "OpenRouter Book",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1790, 200],
      "onError": "continueRegularOutput",
      "continueOnFail": true
    },

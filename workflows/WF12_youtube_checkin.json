        "jsCode": "const vids = $('YouTube Progress Check').first().json.videos_published;\nconst dayNum = $('Day Counter').first().json.day_number;\nlet msg;\nif (vids >= 3) {\n  msg = `Day ${dayNum}: ${vids}/3 videos published. Pipeline running. Keep compounding.`;\n} else if (vids > 0) {\n  msg = `Day ${dayNum}: ${vids}/3 videos published. Pipeline needs attention. Queue tomorrow's batch now.`;\n} else {\n  msg = `Day ${dayNum}: 0/3 videos published. Zero output today. Check the pipeline immediately.`;\n}\nreturn [{ json: { choices: [{ message: { content: msg } }] } }];"

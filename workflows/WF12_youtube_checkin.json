        "jsCode": "const dayData = $('Get Daily Log').first().json;\nconst day = Array.isArray(dayData) ? dayData[0] || {} : dayData || {};\nconst dayCounter = $('Day Counter').first().json;\nconst videosPublished = day.videos_published || 0;\nconst pipelineRunning = day.pipeline_running || false;\nconst target = 3;\n\nreturn [{ json: { ...dayCounter, task: 'youtube_checkin', videos_published: videosPublished, pipeline_running: pipelineRunning, videos_target: target, tone_mode: 'coach_growth' } }];"
      },

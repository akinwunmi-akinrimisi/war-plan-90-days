        "jsCode": "const config = $('Read Config').first().json;\nconst weekNum = $('Day Counter').first().json.week_num;\nfunction getRevenuePhase(wn) {\n  if (wn <= 4) return { phase: 1, weeklyTarget: 1000 };\n  if (wn <= 8) return { phase: 2, weeklyTarget: 5000 };\n  return { phase: 3, weeklyTarget: 20000 };\n}\nconst rp = getRevenuePhase(weekNum);\nconst ntData = $('NT Day Calculator').first().json;\nreturn [{ json: { ...ntData, revenue_phase: rp.phase, weekly_target: rp.weeklyTarget } }];"
      },

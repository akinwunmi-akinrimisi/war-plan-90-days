        "jsCode": "const weekNum = $input.first().json.week_num || $('Day Counter').first().json.week_num || 1;\nlet phase, weeklyTarget, phaseRules;\nif (weekNum <= 4) { phase = 1; weeklyTarget = 1000; phaseRules = 'Volume — 10 proposals/day, accept $200+ gigs, build reviews fast'; }\nelse if (weekNum <= 8) { phase = 2; weeklyTarget = 5000; phaseRules = 'Quality — 3 qualified proposals, $500+ minimum, pitch retainers'; }\nelse { phase = 3; weeklyTarget = 20000; phaseRules = 'Premium — discovery calls, $10K+ proposals, Operscale brand positioning'; }\nreturn [{ json: { ...$('Day Counter').first().json, revenue_phase: phase, weekly_target: weeklyTarget, phase_rules: phaseRules } }];"

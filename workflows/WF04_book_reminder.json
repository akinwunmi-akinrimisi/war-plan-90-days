    {
      "parameters": {
        "jsCode": "// Fallback: static message when OpenRouter fails\nconst dayNum = $('Day Counter').first().json.day_number;\nconst msg = `Day ${dayNum}. Read 50 pages. Knowledge compounds.`;\nreturn [{ json: { fallback_message: msg } }];"

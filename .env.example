# =============================================================================
# .env — 90-Day War Plan · AI Accountability Partner
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ── n8n Instance ─────────────────────────────────────────────────────────────
N8N_URL=https://your-n8n-instance.example.com
N8N_API_KEY=your-n8n-api-key-here

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Get by messaging your bot, then: curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Slack Webhook ────────────────────────────────────────────────────────────
# Slack → Apps → Incoming Webhooks → Add to #war-plan channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXX/BXXXXX/XXXXXXXX

# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API_KEY=your-supabase-anon-key-here

# ── OpenRouter (Claude API) ─────────────────────────────────────────────────
# openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Tracker HTML ─────────────────────────────────────────────────────────────
# Absolute path on the n8n server where 90day-tracker.html lives
TRACKER_HTML_PATH=/opt/war-plan-agent/90day-tracker.html
